{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Validate DSL Checks",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/python",
      "args": [
        "-u",
        "scripts/validate_dsl.py"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "Watch DSL Checks",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/python",
      "args": [
        "-u",
        "scripts/validate_dsl.py",
        "--watch",
        "--interval",
        "0.2"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": {
        "owner": "external",
        "fileLocation": "absolute",
        "severity": "error",
        "pattern": {
          "regexp": "^\\[ERROR\\]\\s+(.+?):(\\d+):(\\d+):\\s+(.*)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "message": 4
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^\\[[0-9]{2}:[0-9]{2}:[0-9]{2}\\] Re-validating\\.\\.\\.$",
          "endsPattern": "^\\[VALIDATION-END\\]$"
        }
      }
    }
  ]
}
