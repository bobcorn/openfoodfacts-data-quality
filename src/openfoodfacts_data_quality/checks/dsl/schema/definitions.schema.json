{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["metadata", "checks"],
  "additionalProperties": false,
  "properties": {
    "metadata": {
      "$ref": "#/$defs/metadata"
    },
    "checks": {
      "type": "array",
      "items": { "$ref": "#/$defs/check" }
    }
  },
  "$defs": {
    "check": {
      "type": "object",
      "required": ["id", "severity", "when"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*:[^\\s]+$"
        },
        "severity": {
          "enum": ["bug", "info", "completeness", "warning", "error"]
        },
        "when": { "$ref": "#/$defs/expression" }
      }
    },
    "metadata": {
      "type": "object",
      "required": ["parity_baseline", "jurisdictions"],
      "additionalProperties": false,
      "properties": {
        "parity_baseline": {
          "enum": ["legacy", "none"]
        },
        "jurisdictions": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": ["global", "ca"]
          }
        }
      }
    },
    "expression": {
      "oneOf": [
        { "$ref": "#/$defs/atom" },
        { "$ref": "#/$defs/all" },
        { "$ref": "#/$defs/any" },
        { "$ref": "#/$defs/not" }
      ]
    },
    "atom": {
      "type": "object",
      "required": ["field", "op"],
      "additionalProperties": false,
      "properties": {
        "field": { "type": "string" },
        "op": {
          "enum": [
            "is_missing",
            "is_blank",
            "is_true",
            "is_false",
            "eq",
            "ne",
            "gt",
            "gte",
            "lt",
            "lte",
            "contains",
            "in",
            "not_in"
          ]
        },
        "value": {}
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "op": { "enum": ["is_blank", "is_true", "is_false"] }
            }
          },
          "then": {
            "not": { "required": ["value"] }
          }
        },
        {
          "if": {
            "properties": {
              "op": { "enum": ["is_missing"] }
            }
          },
          "then": {
            "not": { "required": ["value"] }
          }
        },
        {
          "if": {
            "properties": {
              "op": { "enum": ["eq", "ne", "gt", "gte", "lt", "lte", "contains", "in", "not_in"] }
            }
          },
          "then": {
            "required": ["value"]
          }
        }
      ]
    },
    "all": {
      "type": "object",
      "required": ["all"],
      "additionalProperties": false,
      "properties": {
        "all": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/expression" }
        }
      }
    },
    "any": {
      "type": "object",
      "required": ["any"],
      "additionalProperties": false,
      "properties": {
        "any": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/expression" }
        }
      }
    },
    "not": {
      "type": "object",
      "required": ["not"],
      "additionalProperties": false,
      "properties": {
        "not": { "$ref": "#/$defs/expression" }
      }
    }
  }
}
