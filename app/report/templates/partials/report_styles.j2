      :root {
        --bg: #f5f5f7;
        --surface: #ffffff;
        --surface-subtle: #fafafa;
        --line: #e5e7eb;
        --line-strong: #d0d5dd;
        --ink: #111827;
        --muted: #667085;
        --muted-strong: #475467;
        --pass: #027a48;
        --pass-soft: #ecfdf3;
        --pass-line: #b7ebcd;
        --fail-soft: #fef3f2;
        --fail-line: #f3c1bc;
        --warn: #b54708;
        --shadow: 0 12px 30px rgba(16, 24, 40, 0.05);
        --radius-xl: 24px;
        --radius-lg: 20px;
        --radius-md: 16px;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        background: var(--bg);
        color: var(--ink);
        font-family: ui-sans-serif, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }

      main {
        width: min(1100px, calc(100% - 32px));
        margin: 0 auto;
        padding: 28px 0 72px;
      }

      h1,
      h2,
      h3,
      h4,
      p {
        margin: 0;
      }

      a {
        color: inherit;
      }

      .shell {
        border: 1px solid var(--line);
        border-radius: var(--radius-xl);
        background: var(--surface);
        box-shadow: var(--shadow);
      }

      .page-meta {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 6px 14px;
        margin-bottom: 10px;
        color: var(--muted);
        font-size: 0.61rem;
        line-height: 1.15;
        opacity: 0.8;
      }

      .page-meta__label {
        margin-right: 5px;
        letter-spacing: 0.05em;
        text-transform: uppercase;
      }

      .page-meta code {
        font-family: ui-monospace, "SFMono-Regular", "SF Mono", Menlo, Monaco, Consolas, "Liberation Mono", monospace;
        font-size: 0.69rem;
      }

      .hero {
        padding: 28px;
      }

      .hero-top {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 24px;
        align-items: flex-start;
      }

      .hero-copy {
        display: grid;
        gap: 8px;
        min-width: 0;
        width: 100%;
      }

      .hero-eyebrow {
        color: var(--muted);
        font-size: 0.74rem;
        font-weight: 700;
        letter-spacing: 0.14em;
        text-transform: uppercase;
      }

      .hero h1 {
        font-size: clamp(2rem, 4.5vw, 3rem);
        line-height: 1.03;
        letter-spacing: -0.045em;
        font-weight: 700;
      }

      .hero p {
        color: var(--muted);
        line-height: 1.5;
      }

      .code {
        font-family: ui-monospace, "SFMono-Regular", "SF Mono", Menlo, Monaco, Consolas, "Liberation Mono", monospace;
        font-size: 0.84rem;
      }

      .button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        appearance: none;
        border: 1px solid var(--line);
        border-radius: 999px;
        background: var(--surface-subtle);
        color: var(--ink);
        padding: 10px 14px;
        font: inherit;
        font-size: 0.92rem;
        font-weight: 600;
        cursor: pointer;
        white-space: nowrap;
        text-decoration: none;
      }

      .button:hover {
        border-color: var(--line-strong);
        background: #f4f4f5;
      }

      .button--quiet {
        background: #ffffff;
      }

      .hero-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        align-items: center;
      }

      .hero-action {
        flex: 0 0 auto;
      }

      .export-shell {
        position: relative;
      }

      .export-panel {
        position: absolute;
        right: 0;
        top: calc(100% + 12px);
        z-index: 20;
        min-width: 180px;
        padding: 8px;
        border: 1px solid var(--line);
        border-radius: var(--radius-md);
        background: rgba(255, 255, 255, 0.98);
        box-shadow: var(--shadow);
        display: none;
      }

      .export-panel.is-open {
        display: grid;
        gap: 4px;
      }

      .export-panel__action {
        width: 100%;
        min-height: 40px;
        padding: 0 12px;
        border: 0;
        border-radius: 12px;
        background: transparent;
        color: var(--ink);
        font: inherit;
        font-size: 0.92rem;
        font-weight: 600;
        text-align: left;
        cursor: pointer;
      }

      .export-panel__action:hover {
        background: var(--surface-subtle);
      }

      .stats-grid {
        display: grid;
        grid-template-columns: repeat(5, minmax(0, 1fr));
        gap: 12px;
        margin-top: 24px;
      }

      .stat {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        justify-content: flex-start;
        width: 100%;
        padding: 16px;
        border: 1px solid var(--line);
        border-radius: var(--radius-md);
        background: var(--surface-subtle);
        text-align: left;
      }

      button.stat {
        font: inherit;
        cursor: pointer;
      }

      .stat--pass {
        border-color: var(--pass-line);
        background: var(--pass-soft);
      }

      .stat--fail {
        border-color: var(--fail-line);
        background: var(--fail-soft);
      }

      .stat--interactive:hover {
        filter: brightness(0.985);
      }

      .stat--active {
        box-shadow: inset 0 0 0 1px rgba(17, 24, 39, 0.08);
      }

      .stat__label {
        display: block;
        color: var(--muted);
        font-size: 0.77rem;
        font-weight: 600;
        letter-spacing: 0.06em;
        text-transform: uppercase;
      }

      .stat__value {
        display: block;
        margin-top: 10px;
        font-size: 1.55rem;
        line-height: 1;
        letter-spacing: -0.04em;
        font-weight: 700;
      }

      .stat--hero {
        padding: 18px;
      }

      .stat--detail {
        border-color: var(--line);
        background: var(--surface-subtle);
      }

      .stat--missing {
        border-color: var(--line);
        background: var(--surface-subtle);
      }

      .stat--extra {
        border-color: var(--line);
        background: var(--surface-subtle);
      }

      .stat--detail.stat--pass {
        border-color: var(--pass-line);
        background: var(--pass-soft);
      }

      .stat--detail.stat--fail {
        border-color: var(--fail-line);
        background: var(--fail-soft);
      }

      .section-bar {
        display: flex;
        justify-content: space-between;
        gap: 16px;
        align-items: center;
        margin: 24px 0 14px;
      }

      .checks-shell {
        margin-top: 24px;
        padding: 24px;
      }

      .checks-shell .section-bar {
        margin-top: 0;
      }

      .section-bar h2 {
        font-size: 1.45rem;
        line-height: 1.1;
        letter-spacing: -0.03em;
      }

      .filters-stack {
        display: flex;
        gap: 10px;
        justify-content: flex-end;
        align-items: center;
      }

      .controls-toolbar {
        display: grid;
        grid-template-columns: minmax(240px, 280px) max-content max-content;
        gap: 10px;
        align-items: center;
      }

      .search-shell {
        min-width: 0;
      }

      .search-field {
        display: flex;
        align-items: center;
        gap: 10px;
        min-height: 40px;
        padding: 0 14px;
        border: 1px solid var(--line);
        border-radius: 999px;
        background: var(--surface);
        color: var(--muted-strong);
      }

      .search-field:focus-within {
        border-color: var(--line-strong);
        box-shadow: inset 0 0 0 1px rgba(17, 24, 39, 0.06);
      }

      .search-field__icon {
        width: 16px;
        height: 16px;
        flex: 0 0 auto;
      }

      .search-field input {
        width: 100%;
        border: 0;
        padding: 11px 0;
        background: transparent;
        color: var(--ink);
        font: inherit;
        font-size: 0.92rem;
      }

      .search-field input:focus {
        outline: none;
      }

      .search-field input::placeholder {
        color: var(--muted);
      }

      .search-field input[type="search"]::-webkit-search-cancel-button {
        cursor: pointer;
      }

      .filters-shell {
        position: relative;
      }

      .sort-shell {
        position: relative;
      }

      .toolbar-button {
        gap: 10px;
        min-height: 40px;
        padding: 9px 14px;
        background: var(--surface);
      }

      .toolbar-button:hover {
        border-color: var(--line-strong);
      }

      .toolbar-button.is-active {
        box-shadow: inset 0 0 0 1px rgba(17, 24, 39, 0.08);
      }

      .toolbar-button__icon {
        width: 16px;
        height: 16px;
        flex: 0 0 auto;
      }

      .toolbar-button__count {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 22px;
        height: 22px;
        padding: 0 6px;
        border-radius: 999px;
        background: var(--ink);
        color: #ffffff;
        font-size: 0.74rem;
        font-weight: 700;
      }

      .toolbar-button__count[hidden] {
        display: none;
      }

      .filter-panel {
        position: absolute;
        right: 0;
        top: calc(100% + 12px);
        z-index: 20;
        width: min(360px, calc(100vw - 40px));
        padding: 18px;
        border: 1px solid var(--line);
        border-radius: var(--radius-md);
        background: rgba(255, 255, 255, 0.98);
        box-shadow: var(--shadow);
        display: none;
      }

      .filter-panel.is-open {
        display: grid;
        gap: 16px;
      }

      .filter-panel__head {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        align-items: center;
      }

      .filter-panel__title {
        font-size: 0.9rem;
        font-weight: 700;
        letter-spacing: 0.01em;
      }

      .filter-panel__reset {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 32px;
        padding: 0 12px;
        border: 1px solid var(--line);
        border-radius: 999px;
        background: #ffffff;
        color: var(--muted-strong);
        font: inherit;
        font-size: 0.83rem;
        font-weight: 700;
        cursor: pointer;
      }

      .filter-panel__reset:hover {
        border-color: var(--line-strong);
        background: var(--surface-subtle);
      }

      .filter-grid {
        display: grid;
        gap: 10px;
      }

      .filter-group {
        margin: 0;
        padding: 12px;
        border: 1px solid var(--line);
        border-radius: 14px;
        background: var(--surface-subtle);
        display: grid;
        gap: 10px;
      }

      .filter-group legend {
        padding: 0;
        color: var(--muted);
        font-size: 0.73rem;
        font-weight: 700;
        letter-spacing: 0.06em;
        text-transform: uppercase;
      }

      .filter-options {
        display: grid;
        gap: 6px;
      }

      .filter-option {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 9px 10px;
        border: 1px solid var(--line);
        border-radius: 12px;
        background: #ffffff;
        color: var(--muted-strong);
        font-size: 0.88rem;
        cursor: pointer;
      }

      .filter-option:hover {
        border-color: var(--line-strong);
        background: #fcfcfd;
      }

      .filter-option input[type="checkbox"],
      .filter-option input[type="radio"] {
        margin: 0;
        accent-color: var(--ink);
      }

      .sort-panel {
        width: min(320px, calc(100vw - 40px));
      }

      .composition {
        margin-top: 18px;
        padding-top: 18px;
        border-top: 1px solid var(--line);
      }

      .composition-header {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        align-items: center;
        margin-bottom: 12px;
      }

      .composition-label {
        color: var(--muted);
        font-size: 0.78rem;
        font-weight: 600;
        letter-spacing: 0.06em;
        text-transform: uppercase;
      }

      .composition-bar {
        display: flex;
        width: 100%;
        height: 14px;
        overflow: hidden;
        border-radius: 999px;
        background: #f2f4f7;
      }

      .composition-segment {
        min-width: 0;
        border: 0;
        padding: 0;
        cursor: pointer;
      }

      .composition-segment--pass {
        background: var(--pass);
      }

      .composition-segment--legacy_only {
        background: #d9822f;
      }

      .composition-segment--migrated_only {
        background: #d14d41;
      }

      .composition-segment--mixed {
        background: #8f1d1d;
      }

      .composition-segment--runtime_only {
        background: #506176;
      }

      .composition-segment.is-active {
        filter: brightness(0.88);
      }

      .composition-legend {
        display: flex;
        flex-wrap: wrap;
        gap: 10px 16px;
        margin-top: 12px;
      }

      .composition-item {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: var(--muted-strong);
        font-size: 0.88rem;
      }

      .composition-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        flex: 0 0 auto;
      }

      .composition-dot--pass {
        background: var(--pass);
      }

      .composition-dot--legacy_only {
        background: #d9822f;
      }

      .composition-dot--migrated_only {
        background: #d14d41;
      }

      .composition-dot--mixed {
        background: #8f1d1d;
      }

      .composition-dot--runtime_only {
        background: #506176;
      }

      .checks {
        display: grid;
        gap: 14px;
      }

      .empty-state {
        display: grid;
        gap: 8px;
        margin-top: 14px;
        padding: 22px;
        border: 1px dashed var(--line);
        border-radius: var(--radius-md);
        background: var(--surface-subtle);
      }

      .empty-state[hidden] {
        display: none;
      }

      .empty-state h3 {
        font-size: 1.05rem;
        letter-spacing: -0.02em;
      }

      .empty-state p {
        color: var(--muted);
        line-height: 1.5;
      }

      .check {
        border: 1px solid var(--line);
        border-radius: var(--radius-lg);
        background: var(--surface);
        box-shadow: var(--shadow);
        overflow: hidden;
      }

      .check[hidden] {
        display: none;
      }

      .check--pass {
        border-color: var(--pass-line);
        background: var(--pass-soft);
      }

      .check--fail {
        border-color: var(--fail-line);
        background: var(--fail-soft);
      }

      .check--runtime_only {
        border-color: rgba(80, 97, 118, 0.28);
        background: #eef2f7;
      }

      .check-head {
        padding: 20px 22px 16px;
      }

      .check-topline {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        align-items: flex-start;
      }

      .status-cluster {
        display: inline-flex;
        align-items: center;
        gap: 0;
        flex: 0 0 auto;
        padding-top: 2px;
        margin-left: auto;
      }

      .status-indicator {
        display: inline-flex;
        align-items: center;
        line-height: 0;
      }

      .status-indicator--pass {
        color: var(--pass);
      }

      .status-indicator--fail {
        color: var(--warn);
      }

      .status-indicator--runtime_only {
        color: #506176;
      }

      .status-indicator svg {
        width: 22px;
        height: 22px;
      }

      .check-title {
        display: grid;
        gap: 8px;
        min-width: 0;
        flex: 1 1 auto;
      }

      .check-title h3 {
        font-size: 1.28rem;
        line-height: 1.2;
        letter-spacing: -0.03em;
      }

      .check-body {
        display: grid;
        gap: 14px;
        padding: 0 22px 22px;
      }

      .metrics {
        display: flex;
        flex-wrap: wrap;
        gap: 16px 18px;
        padding-top: 14px;
        border-top: 1px solid var(--line);
      }

      .metric {
        display: grid;
        gap: 4px;
        min-width: 86px;
      }

      .metric__label {
        color: var(--muted);
        font-size: 0.74rem;
        font-weight: 600;
        letter-spacing: 0.06em;
        text-transform: uppercase;
      }

      .metric strong {
        font-size: 1rem;
        font-weight: 700;
      }

      .disclosure {
        display: grid;
        gap: 0;
        border: 1px solid var(--line);
        border-radius: var(--radius-md);
        background: rgba(255, 255, 255, 0.78);
        overflow: hidden;
      }

      .disclosure-summary {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        align-items: center;
        list-style: none;
        cursor: pointer;
        padding: 12px 14px;
        border: 0;
        background: transparent;
      }

      .disclosure-summary::-webkit-details-marker {
        display: none;
      }

      .disclosure-summary-copy {
        display: inline-flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 8px;
      }

      .disclosure-summary-label {
        font-size: 0.86rem;
        font-weight: 700;
      }

      .disclosure-summary-indicator {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 28px;
        height: 28px;
        border-radius: 999px;
        border: 1px solid var(--line);
        background: var(--surface);
        color: var(--muted-strong);
        font-size: 1rem;
        font-weight: 600;
        line-height: 1;
        flex: 0 0 auto;
      }

      .disclosure-summary-indicator::before {
        content: "+";
      }

      .disclosure[open] .disclosure-summary-indicator::before {
        content: "\2212";
      }

      .details-grid {
        display: grid;
        gap: 12px;
        padding: 0 14px 14px;
      }

      .snippet-panel {
        display: grid;
        gap: 12px;
        padding: 0 14px 14px;
      }

      .snippet-notes {
        display: grid;
        gap: 8px;
      }

      .snippet-note {
        margin: 0;
        padding: 10px 12px;
        border: 1px solid rgba(210, 161, 74, 0.34);
        border-radius: var(--radius-md);
        background: rgba(255, 245, 220, 0.7);
        color: #6f5421;
        font-size: 0.82rem;
        line-height: 1.5;
      }

      .snippet-block {
        display: grid;
        gap: 8px;
        overflow-x: auto;
        color: var(--ink);
      }

      .snippet-block pre {
        margin: 0;
        padding: 0 0 0 0;
        color: var(--ink);
        font-family: ui-monospace, "SFMono-Regular", "SF Mono", Menlo, Monaco, Consolas, "Liberation Mono", monospace;
        font-size: 0.82rem;
        line-height: 1.6;
        white-space: pre;
      }

      .panel {
        display: grid;
        gap: 8px;
      }

      .panel-head {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        align-items: center;
        padding: 0;
      }

      .panel-head h4 {
        font-size: 0.96rem;
        font-weight: 700;
      }

      .panel-head span {
        color: var(--muted);
        font-size: 0.86rem;
      }

      .table-wrap {
        overflow-x: auto;
        border: 1px solid var(--line);
        border-radius: var(--radius-md);
        background: rgba(255, 255, 255, 0.82);
      }

      table {
        width: 100%;
        min-width: 720px;
        border-collapse: collapse;
      }

      thead th {
        padding: 12px 16px;
        text-align: left;
        border-bottom: 1px solid var(--line);
        color: var(--muted);
        font-size: 0.74rem;
        font-weight: 700;
        letter-spacing: 0.06em;
        text-transform: uppercase;
      }

      tbody td {
        padding: 14px 16px;
        border-top: 1px solid var(--line);
        vertical-align: top;
        line-height: 1.5;
      }

      .findings-table tbody td {
        font-family: ui-monospace, "SFMono-Regular", "SF Mono", Menlo, Monaco, Consolas, "Liberation Mono", monospace;
        font-size: 0.84rem;
      }

      tbody tr:first-child td {
        border-top: 0;
      }

      .term {
        cursor: help;
        border-bottom: 1px dotted var(--line-strong);
      }

      .has-tooltip {
        cursor: help;
      }

      .sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
      }

      .tooltip {
        position: fixed;
        left: 0;
        top: 0;
        max-width: 280px;
        padding: 10px 12px;
        border-radius: 12px;
        background: rgba(17, 24, 39, 0.96);
        color: #ffffff;
        font-size: 0.84rem;
        line-height: 1.45;
        box-shadow: 0 18px 30px rgba(17, 24, 39, 0.22);
        pointer-events: none;
        z-index: 9999;
        opacity: 0;
        transform: translate(-9999px, -9999px);
        transition: opacity 120ms ease;
      }

      .tooltip.is-visible {
        opacity: 1;
      }

      @media (max-width: 960px) {
        .stats-grid {
          grid-template-columns: repeat(3, minmax(0, 1fr));
        }
      }

      @media (max-width: 860px) {
        .hero-top {
          grid-template-columns: minmax(0, 1fr);
        }

        .stats-grid {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .section-bar {
          flex-direction: column;
          align-items: flex-start;
        }

        .filters-stack {
          justify-content: flex-start;
          text-align: left;
        }

        .filters-stack,
        .controls-toolbar {
          width: 100%;
        }

        .controls-toolbar {
          display: flex;
          flex-wrap: wrap;
        }

        .search-shell {
          flex: 1 1 100%;
        }

        .filter-panel {
          left: 0;
          right: auto;
        }

        .export-panel {
          left: 0;
          right: auto;
        }
      }

      @media (max-width: 640px) {
        main {
          width: min(100% - 20px, 1100px);
          padding-top: 18px;
        }

        .hero,
        .checks-shell,
        .check-head,
        .check-body {
          padding-left: 18px;
          padding-right: 18px;
        }

        .stats-grid {
          grid-template-columns: minmax(0, 1fr);
        }

        thead th,
        tbody td {
          padding-left: 14px;
          padding-right: 14px;
        }
      }

      @media print {
        body {
          background: #ffffff;
        }

        .button,
        .filters-stack,
        .filter-panel,
        .tooltip {
          display: none !important;
        }

        .disclosure {
          border: 0;
        }

        .disclosure-summary {
          display: none !important;
        }

        .disclosure > .snippet-panel,
        .disclosure > .details-grid {
          display: grid !important;
          padding: 0;
        }

        .shell,
        .check {
          box-shadow: none;
        }
      }
