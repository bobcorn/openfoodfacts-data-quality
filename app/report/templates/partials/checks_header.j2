      <div class="section-bar">
        <h2><span id="visible-check-count">{{ checks_evaluated }}</span> <span id="visible-check-label">{% if checks_evaluated == 1 %}check{% else %}checks{% endif %}</span></h2>
        <div class="filters-stack">
          <div class="controls-toolbar">
            <div class="search-shell">
              <label class="search-field" for="check-search">
                <svg class="search-field__icon" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <circle cx="7" cy="7" r="4.5" stroke="currentColor" stroke-width="1.4"></circle>
                  <path d="m10.5 10.5 3 3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"></path>
                </svg>
                <input
                  id="check-search"
                  type="search"
                  autocomplete="off"
                  spellcheck="false"
                  placeholder="{{ terms.controls.search_placeholder }}"
                  aria-label="{{ terms.controls.search_label }}"
                >
              </label>
            </div>
            <div class="filters-shell">
              <button
                class="button toolbar-button"
                id="filter-toggle"
                type="button"
                aria-haspopup="true"
                aria-expanded="false"
                aria-controls="filter-panel"
              >
                <svg class="toolbar-button__icon" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <path d="M2 3h12l-4.6 5.25v3.35L6.6 13V8.25L2 3Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"></path>
                </svg>
                <span>{{ terms.controls.filters_label }}</span>
                <span class="toolbar-button__count" id="filter-count" hidden>0</span>
              </button>

              <div class="filter-panel" id="filter-panel" role="dialog" aria-label="{{ terms.controls.filters_label }}">
                <div class="filter-panel__head">
                  <div class="filter-panel__title">{{ terms.controls.filters_label }}</div>
                  <button class="filter-panel__reset" id="clear-filters" type="button">{{ terms.controls.clear_filters }}</button>
                </div>

                <div class="filter-grid">
                  <fieldset class="filter-group">
                    <legend>{{ terms.controls.filter_groups.outcome }}</legend>
                    <div class="filter-options">
                      <label class="filter-option">
                        <input type="checkbox" data-filter-group="outcome" value="pass">
                        <span>{{ terms.outcomes.pass.label }}</span>
                      </label>
                      <label class="filter-option">
                        <input type="checkbox" data-filter-group="outcome" value="legacy_only">
                        <span>{{ terms.outcomes.legacy_only.label }}</span>
                      </label>
                      <label class="filter-option">
                        <input type="checkbox" data-filter-group="outcome" value="migrated_only">
                        <span>{{ terms.outcomes.migrated_only.label }}</span>
                      </label>
                      <label class="filter-option">
                        <input type="checkbox" data-filter-group="outcome" value="mixed">
                        <span>{{ terms.outcomes.mixed.label }}</span>
                      </label>
                      <label class="filter-option">
                        <input type="checkbox" data-filter-group="outcome" value="runtime_only">
                        <span>{{ terms.outcomes.runtime_only.label }}</span>
                      </label>
                    </div>
                  </fieldset>

                  <fieldset class="filter-group">
                    <legend>{{ terms.controls.filter_groups.definition_language }}</legend>
                    <div class="filter-options">
                      <label class="filter-option">
                        <input type="checkbox" data-filter-group="definitionLanguage" value="python">
                        <span>{{ terms.definition_language.python.label }}</span>
                      </label>
                      <label class="filter-option">
                        <input type="checkbox" data-filter-group="definitionLanguage" value="dsl">
                        <span>{{ terms.definition_language.dsl.label }}</span>
                      </label>
                    </div>
                  </fieldset>
                </div>
              </div>
            </div>

            <div class="sort-shell">
              <button
                class="button toolbar-button"
                id="sort-toggle"
                type="button"
                aria-haspopup="true"
                aria-expanded="false"
                aria-controls="sort-panel"
              >
                <svg class="toolbar-button__icon" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <path d="M5 3v10M5 3 2.5 5.5M5 3l2.5 2.5M11 13V3M11 13 8.5 10.5M11 13l2.5-2.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
                </svg>
                <span>{{ terms.controls.sort_by_label }}</span>
              </button>

              <div class="filter-panel sort-panel" id="sort-panel" role="dialog" aria-label="{{ terms.controls.sort_by_label }}">
                <div class="filter-panel__head">
                  <div class="filter-panel__title">{{ terms.controls.sort_by_label }}</div>
                </div>

                <div class="filter-grid">
                  <fieldset class="filter-group">
                    <legend>{{ terms.controls.sort_metric_label }}</legend>
                    <div class="filter-options">
                      <label class="filter-option">
                        <input type="radio" name="sort-field" value="total_mismatches" checked>
                        <span>{{ terms.controls.sort_options.total_mismatches }}</span>
                      </label>
                      <label class="filter-option">
                        <input type="radio" name="sort-field" value="missing_count">
                        <span>{{ terms.controls.sort_options.missing_count }}</span>
                      </label>
                      <label class="filter-option">
                        <input type="radio" name="sort-field" value="extra_count">
                        <span>{{ terms.controls.sort_options.extra_count }}</span>
                      </label>
                      <label class="filter-option">
                        <input type="radio" name="sort-field" value="matched_count">
                        <span>{{ terms.controls.sort_options.matched_count }}</span>
                      </label>
                      <label class="filter-option">
                        <input type="radio" name="sort-field" value="migrated_count">
                        <span>{{ terms.controls.sort_options.migrated_count }}</span>
                      </label>
                      <label class="filter-option">
                        <input type="radio" name="sort-field" value="check_id">
                        <span>{{ terms.controls.sort_options.check_id }}</span>
                      </label>
                    </div>
                  </fieldset>

                  <fieldset class="filter-group">
                    <legend>{{ terms.controls.sort_direction_label }}</legend>
                    <div class="filter-options">
                      <label class="filter-option">
                        <input type="radio" name="sort-direction" value="desc" checked>
                        <span>{{ terms.controls.descending }}</span>
                      </label>
                      <label class="filter-option">
                        <input type="radio" name="sort-direction" value="asc">
                        <span>{{ terms.controls.ascending }}</span>
                      </label>
                    </div>
                  </fieldset>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
