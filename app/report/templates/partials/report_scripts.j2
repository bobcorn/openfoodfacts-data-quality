      (function () {
        const exportToggle = document.getElementById("export-toggle");
        const exportPanel = document.getElementById("export-panel");
        const exportHtmlButton = document.getElementById("export-html");
        const exportPdfButton = document.getElementById("export-pdf");
        const exportJsonButton = document.getElementById("export-json");
        const mismatchParityValues = ["legacy_only", "migrated_only", "mixed"];
        const statButtons = Array.from(document.querySelectorAll(".stat[data-kind-filter]"));
        const compositionButtons = Array.from(document.querySelectorAll(".composition-segment"));
        const checksContainer = document.querySelector(".checks");
        const checks = Array.from(checksContainer.querySelectorAll(".check"));
        const visibleCheckCount = document.getElementById("visible-check-count");
        const visibleCheckLabel = document.getElementById("visible-check-label");
        const searchInput = document.getElementById("check-search");
        const filterToggle = document.getElementById("filter-toggle");
        const filterPanel = document.getElementById("filter-panel");
        const filterCount = document.getElementById("filter-count");
        const clearFiltersButton = document.getElementById("clear-filters");
        const filterInputs = Array.from(document.querySelectorAll("[data-filter-group]"));
        const sortToggle = document.getElementById("sort-toggle");
        const sortPanel = document.getElementById("sort-panel");
        const sortFieldInputs = Array.from(document.querySelectorAll('input[name="sort-field"]'));
        const sortDirectionInputs = Array.from(document.querySelectorAll('input[name="sort-direction"]'));
        const emptyState = document.getElementById("empty-state");
        const tooltip = document.getElementById("tooltip");
        const tooltipTerms = Array.from(document.querySelectorAll("[data-tooltip]"));
        const parityPriority = {
          mixed: 0,
          legacy_only: 1,
          migrated_only: 2,
          pass: 3,
        };

        const filters = {
          parity: new Set(),
          definitionLanguage: new Set(),
        };

        const sortState = {
          field: "total_mismatches",
          direction: "desc",
        };

        let searchQuery = "";

        checks.forEach((check, index) => {
          check.dataset.originalIndex = String(index);
        });

        function isSameSelection(current, values) {
          if (current.size !== values.length) {
            return false;
          }
          return values.every((value) => current.has(value));
        }

        function getFilterCount() {
          return filters.parity.size + filters.definitionLanguage.size;
        }

        function toggleFilterPanel(forceOpen) {
          const nextState = typeof forceOpen === "boolean" ? forceOpen : !filterPanel.classList.contains("is-open");
          if (nextState) {
            toggleSortPanel(false);
          }
          filterPanel.classList.toggle("is-open", nextState);
          filterToggle.setAttribute("aria-expanded", nextState ? "true" : "false");
          filterToggle.classList.toggle("is-active", nextState || getFilterCount() > 0);
        }

        function toggleSortPanel(forceOpen) {
          const nextState = typeof forceOpen === "boolean" ? forceOpen : !sortPanel.classList.contains("is-open");
          if (nextState) {
            toggleFilterPanel(false);
          }
          sortPanel.classList.toggle("is-open", nextState);
          sortToggle.setAttribute("aria-expanded", nextState ? "true" : "false");
          sortToggle.classList.toggle("is-active", nextState);
        }

        function toggleExportPanel(forceOpen) {
          const nextState = typeof forceOpen === "boolean" ? forceOpen : !exportPanel.classList.contains("is-open");
          exportPanel.classList.toggle("is-open", nextState);
          exportToggle.setAttribute("aria-expanded", nextState ? "true" : "false");
          exportToggle.classList.toggle("is-active", nextState);
        }

        function syncFilterUi() {
          const activeCount = getFilterCount();
          filterCount.hidden = activeCount === 0;
          filterCount.textContent = String(activeCount);
          filterToggle.classList.toggle("is-active", filterPanel.classList.contains("is-open") || activeCount > 0);

          filterInputs.forEach((input) => {
            input.checked = filters[input.dataset.filterGroup].has(input.value);
          });

          statButtons.forEach((button) => {
            const buttonKind = button.dataset.kindFilter;
            const isActive = buttonKind === "pass"
              ? isSameSelection(filters.parity, ["pass"])
              : isSameSelection(filters.parity, mismatchParityValues);
            button.classList.toggle("stat--active", isActive);
            button.setAttribute("aria-pressed", isActive ? "true" : "false");
          });

          compositionButtons.forEach((button) => {
            const isActive = filters.parity.has(button.dataset.kindFilter);
            button.classList.toggle("is-active", isActive);
            button.setAttribute("aria-pressed", isActive ? "true" : "false");
          });
        }

        function matchesFilterGroup(value, selectedValues) {
          return selectedValues.size === 0 || selectedValues.has(value);
        }

        function applyFilters() {
          let visibleChecks = 0;
          checks.forEach((check) => {
            const parityMatch = matchesFilterGroup(check.dataset.parityOutcome, filters.parity);
            const definitionLanguageMatch = matchesFilterGroup(
              check.dataset.definitionLanguage,
              filters.definitionLanguage
            );
            const searchMatch = searchQuery === "" || check.dataset.searchText.includes(searchQuery);
            check.hidden = !(parityMatch && definitionLanguageMatch && searchMatch);
            if (!check.hidden) {
              visibleChecks += 1;
            }
          });
          visibleCheckCount.textContent = String(visibleChecks);
          visibleCheckLabel.textContent = visibleChecks === 1 ? "check" : "checks";
          emptyState.hidden = visibleChecks > 0;
        }

        function compareChecks(a, b) {
          let primaryResult = 0;
          switch (sortState.field) {
            case "missing_count":
              primaryResult = Number(a.dataset.missingCount) - Number(b.dataset.missingCount);
              break;
            case "extra_count":
              primaryResult = Number(a.dataset.extraCount) - Number(b.dataset.extraCount);
              break;
            case "matched_count":
              primaryResult = Number(a.dataset.matchedCount) - Number(b.dataset.matchedCount);
              break;
            case "check_id":
              primaryResult = a.dataset.checkId.localeCompare(b.dataset.checkId);
              break;
            default:
              primaryResult = Number(a.dataset.totalMismatches) - Number(b.dataset.totalMismatches);
              break;
          }

          if (primaryResult !== 0) {
            return sortState.direction === "asc" ? primaryResult : -primaryResult;
          }

          return (
            parityPriority[a.dataset.parityOutcome] - parityPriority[b.dataset.parityOutcome]
            || a.dataset.checkId.localeCompare(b.dataset.checkId)
            || Number(a.dataset.originalIndex) - Number(b.dataset.originalIndex)
          );
        }

        function sortChecks() {
          checks
            .slice()
            .sort(compareChecks)
            .forEach((check) => checksContainer.appendChild(check));
        }

        function renderChecks() {
          syncFilterUi();
          sortChecks();
          applyFilters();
        }

        function clearAllFilters() {
          filters.parity.clear();
          filters.definitionLanguage.clear();
          renderChecks();
        }

        statButtons.forEach((button) => {
          button.addEventListener("click", () => {
            if (button.dataset.kindFilter === "pass") {
              if (isSameSelection(filters.parity, ["pass"])) {
                filters.parity.clear();
              } else {
                filters.parity = new Set(["pass"]);
              }
            } else if (isSameSelection(filters.parity, mismatchParityValues)) {
              filters.parity.clear();
            } else {
              filters.parity = new Set(mismatchParityValues);
            }
            renderChecks();
          });
        });

        compositionButtons.forEach((button) => {
          button.addEventListener("click", () => {
            const value = button.dataset.kindFilter;
            if (filters.parity.has(value)) {
              filters.parity.delete(value);
            } else {
              filters.parity.add(value);
            }
            renderChecks();
          });
        });

        filterInputs.forEach((input) => {
          input.addEventListener("change", () => {
            const selectedValues = filters[input.dataset.filterGroup];
            if (input.checked) {
              selectedValues.add(input.value);
            } else {
              selectedValues.delete(input.value);
            }
            renderChecks();
          });
        });

        filterToggle.addEventListener("click", (event) => {
          event.stopPropagation();
          toggleFilterPanel();
        });

        clearFiltersButton.addEventListener("click", () => {
          clearAllFilters();
        });

        sortToggle.addEventListener("click", (event) => {
          event.stopPropagation();
          toggleSortPanel();
        });

        sortFieldInputs.forEach((input) => {
          input.addEventListener("change", () => {
            if (input.checked) {
              sortState.field = input.value;
              renderChecks();
            }
          });
        });

        sortDirectionInputs.forEach((input) => {
          input.addEventListener("change", () => {
            if (input.checked) {
              sortState.direction = input.value;
              renderChecks();
            }
          });
        });

        searchInput.addEventListener("input", () => {
          searchQuery = searchInput.value.trim().toLowerCase();
          renderChecks();
        });

        exportToggle.addEventListener("click", (event) => {
          event.stopPropagation();
          toggleExportPanel();
        });

        async function downloadArtifact({
          relativeUrl,
          downloadName,
          mimeType,
          pickerDescription,
          pickerExtensions,
        }) {
          const artifactUrl = new URL(relativeUrl, window.location.href);

          async function triggerDirectDownload() {
            try {
              const response = await fetch(artifactUrl, { cache: "no-store" });
              if (!response.ok) {
                throw new Error("Failed to fetch artifact");
              }
              const blob = await response.blob();
              const objectUrl = URL.createObjectURL(blob);
              const link = document.createElement("a");
              link.href = objectUrl;
              link.download = downloadName;
              document.body.appendChild(link);
              link.click();
              link.remove();
              setTimeout(() => URL.revokeObjectURL(objectUrl), 0);
            } catch (error) {
              const link = document.createElement("a");
              link.href = artifactUrl.toString();
              link.download = downloadName;
              document.body.appendChild(link);
              link.click();
              link.remove();
            }
          }

          try {
            if ("showSaveFilePicker" in window) {
              const handle = await window.showSaveFilePicker({
                suggestedName: downloadName,
                types: [
                  {
                    description: pickerDescription,
                    accept: { [mimeType]: pickerExtensions },
                  },
                ],
              });
              const response = await fetch(artifactUrl, { cache: "no-store" });
              if (!response.ok) {
                throw new Error("Failed to fetch artifact");
              }
              const blob = await response.blob();
              const writable = await handle.createWritable();
              await writable.write(blob);
              await writable.close();
              return;
            }

            await triggerDirectDownload();
          } catch (error) {
            if (error && error.name === "AbortError") {
              return;
            }
            await triggerDirectDownload();
          }
        }

        exportHtmlButton.addEventListener("click", async () => {
          toggleExportPanel(false);
          await downloadArtifact({
            relativeUrl: "report.html",
            downloadName: "openfoodfacts-data-quality-report.html",
            mimeType: "text/html",
            pickerDescription: "HTML report",
            pickerExtensions: [".html"],
          });
        });

        exportPdfButton.addEventListener("click", () => {
          toggleExportPanel(false);
          window.print();
        });

        exportJsonButton.addEventListener("click", async () => {
          toggleExportPanel(false);
          await downloadArtifact({
            relativeUrl: "openfoodfacts-data-quality-json.zip",
            downloadName: "openfoodfacts-data-quality-json.zip",
            mimeType: "application/zip",
            pickerDescription: "JSON artifacts archive",
            pickerExtensions: [".zip"],
          });
        });

        document.addEventListener("click", (event) => {
          if (!event.target.closest(".export-shell")) {
            toggleExportPanel(false);
          }
          if (!event.target.closest(".filters-shell")) {
            toggleFilterPanel(false);
          }
          if (!event.target.closest(".sort-shell")) {
            toggleSortPanel(false);
          }
        });

        document.addEventListener("keydown", (event) => {
          if (event.key === "Escape") {
            toggleExportPanel(false);
            toggleFilterPanel(false);
            toggleSortPanel(false);
          }
        });

        renderChecks();

        function positionTooltip(clientX, clientY) {
          const offset = 14;
          const padding = 16;
          const rect = tooltip.getBoundingClientRect();
          let left = clientX + offset;
          let top = clientY + offset;

          if (left + rect.width > window.innerWidth - padding) {
            left = window.innerWidth - rect.width - padding;
          }

          if (top + rect.height > window.innerHeight - padding) {
            top = clientY - rect.height - offset;
          }

          tooltip.style.transform = "translate(" + left + "px, " + top + "px)";
        }

        function showTooltip(event, element) {
          tooltip.textContent = element.dataset.tooltip;
          tooltip.classList.add("is-visible");
          tooltip.setAttribute("aria-hidden", "false");
          positionTooltip(event.clientX, event.clientY);
        }

        function hideTooltip() {
          tooltip.classList.remove("is-visible");
          tooltip.setAttribute("aria-hidden", "true");
          tooltip.style.transform = "translate(-9999px, -9999px)";
        }

        tooltipTerms.forEach((element) => {
          element.addEventListener("mouseenter", (event) => showTooltip(event, element));
          element.addEventListener("mousemove", (event) => positionTooltip(event.clientX, event.clientY));
          element.addEventListener("mouseleave", hideTooltip);
        });

        window.addEventListener("scroll", hideTooltip, { passive: true });
        window.addEventListener("resize", hideTooltip);
      })();
