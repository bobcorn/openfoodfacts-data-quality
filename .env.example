# --- Frequently changed settings. ---
# These are the values most local runs tend to tweak.

# Host-side source snapshot mounted into the container for application runs.
SOURCE_SNAPSHOT_PATH=./examples/data/products.jsonl

# Named check profile from config/check-profiles.toml.
CHECK_PROFILE=full

# Named dataset profile from config/dataset-profiles.toml.
SOURCE_DATASET_PROFILE=full

# Bind the local Docker preview to this host interface.
MIGRATION_BIND_HOST=127.0.0.1

# Local preview port exposed by docker compose and the preview server.
MIGRATION_PORT=8000

# --- Less commonly changed settings. ---
# The defaults below are usually fine, but you can override them when needed.

# Number of source rows fetched into each application batch.
BATCH_SIZE=1000

# Concurrent Python batch workers used by the application runner.
BATCH_WORKERS=1

# Persistent legacy backend worker processes kept warm for reference loading.
LEGACY_BACKEND_WORKERS=1

# Per-check mismatch examples retained for each side in artifacts and reports.
MISMATCH_EXAMPLES_LIMIT=20

# Application-owned parity store path. Relative paths resolve from the repo root.
PARITY_STORE_PATH=./data/parity_store/parity.duckdb

# Optional legacy inventory artifact used to attach migration-family metadata.
# Uncomment after generating the inventory export.
# MIGRATION_INVENTORY_PATH=./artifacts/legacy_inventory/legacy_families.json

# Optional planning sheet joined onto the legacy inventory metadata.
# Uncomment after generating the estimation sheet export.
# MIGRATION_ESTIMATION_SHEET_PATH=./artifacts/legacy_inventory/estimation_sheet.csv
